generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
  output     = "../node_modules/.prisma/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum DocumentType {
  QUOTATION
  INVOICE
  RECEIPT
  DEPOSIT_RECEIPT
  DEPOSIT_INVOICE
  PURCHASE_ORDER
  WORK_ORDER
  DELIVERY_ORDER
  CUSTOMER_RETURN
}

enum StockMoveType {
  IN
  OUT
  INIT
}

enum PaymentType {
  CASH
  CREDIT
  TRANSFER
}

enum DepositInvoiceStatus {
  DRAFT           @map("Draft")
  SENT            @map("Sent")
  AWAITING_VERIFY @map("Awaiting_Verify")
  PAID            @map("Paid")
}

enum SerialNumberStatus {
  AVAILABLE
  SOLD
  RESERVED
  DAMAGED

  @@map("SerialNumberStatus")
}

model User {
  id        String   @id @map("ID") @db.Char(26)
  email     String   @unique @map("Email") @db.VarChar(191)
  password  String   @map("Password") @db.VarChar(255)
  name      String   @map("Name") @db.VarChar(255)
  role      String   @default("user") @map("Role") @db.VarChar(50)
  companyId String?  @map("CompanyID") @db.VarChar(191)
  tokenId   String?  @map("TokenID") @db.VarChar(191)
  createdAt DateTime @default(now()) @map("CreatedAt")
  updatedAt DateTime @updatedAt @map("UpdatedAt")
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([email])
  @@index([companyId])
}

model Customer {
  id           String   @id @map("ID") @db.VarChar(26)
  customerCode String   @map("CustomerCode") @db.VarChar(50)
  customerName String   @map("CustomerName") @db.VarChar(255)
  contactName  String?  @map("ContactName") @db.VarChar(255)
  phone        String?  @map("Phone") @db.VarChar(50)
  email        String?  @map("Email") @db.VarChar(100)
  address      String?  @map("Address") @db.Text
  taxId        String?  @map("TaxID") @db.VarChar(50)
  branch       String?  @map("Branch") @db.VarChar(50)
  fax          String?  @map("Fax") @db.VarChar(50)
  idTerm       String?  @map("IdTerm") @db.VarChar(50)
  used         String?  @map("Used") @db.VarChar(1)
  companyId    String   @map("CompanyID") @db.VarChar(191)
  createdAt    DateTime @default(now()) @map("CreatedAt")
  updatedAt    DateTime @updatedAt @map("UpdatedAt")
  company      Company  @relation("CustomerCompany", fields: [companyId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([companyId, customerCode])
  @@index([companyId])
}

model Product {
  id            String   @id @map("ID") @db.VarChar(26)
  productCode   String   @map("ProductCode") @db.VarChar(50)
  productName   String   @map("ProductName") @db.VarChar(255)
  description   String?  @map("Description") @db.VarChar(500)
  category      String   @map("Category") @db.VarChar(255)
  brand         String   @map("Brand") @db.VarChar(255)
  model         String?  @map("Model") @db.VarChar(255)
  price         Decimal  @map("Price") @db.Decimal(19, 4)
  cost          Decimal? @map("Cost") @db.Decimal(19, 4)
  unitCode      String?  @map("UnitCode") @db.VarChar(50)
  stockQty      Int      @default(0) @map("StockQty")
  minQty        Int      @default(0) @map("MinQty")
  maxQty        Int      @default(0) @map("MaxQty")
  companyId         String             @map("CompanyID") @db.VarChar(191)
  createdAt         DateTime           @default(now()) @map("CreatedAt")
  updatedAt         DateTime           @updatedAt @map("UpdatedAt")
  company           Company            @relation("ProductCompany", fields: [companyId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  stockTransactions StockTransaction[]
  serialNumbers     SerialNumber[]

  @@unique([companyId, productCode])
  @@index([companyId])
}

model Destination {
  id              String  @id @map("ID") @db.VarChar(26)
  destinationCode String  @map("DestinationCode") @db.VarChar(50)
  destination     String? @map("Destination") @db.VarChar(50)
  location        String? @map("Location") @db.VarChar(50)
  used            String? @map("Used") @db.VarChar(1)
  companyId       String  @map("CompanyID") @db.VarChar(191)
  company         Company @relation("DestinationCompany", fields: [companyId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([companyId])
}

model UnitCode {
  id        String  @id @map("ID") @db.VarChar(26)
  unitCode  String  @map("UnitCode") @db.VarChar(50)
  unitName  String? @map("UnitName") @db.VarChar(100)
  shortName String? @map("ShortName") @db.VarChar(20)
  used      String? @map("Used") @db.VarChar(1)
  companyId String  @map("CompanyID") @db.VarChar(191)
  company   Company @relation("UnitCodeCompany", fields: [companyId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([companyId])
}

model PaymentTerm {
  id        String  @id @map("ID") @db.VarChar(26)
  termCode  String  @map("TermCode") @db.VarChar(50)
  termName  String? @map("TermName") @db.VarChar(50)
  shortName String? @map("ShortName") @db.VarChar(20)
  days      String? @map("Days") @db.VarChar(3)
  used      String? @map("Used") @db.VarChar(1)
  companyId String  @map("CompanyID") @db.VarChar(191)
  company   Company @relation("PaymentTermCompany", fields: [companyId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([companyId])
}

model Vendor {
  id           String      @id @map("ID") @db.VarChar(26)
  vendorCode   String      @map("VendorCode") @db.VarChar(50)
  name         String      @map("Name") @db.VarChar(255)
  contactName  String?     @map("ContactName") @db.VarChar(255)
  phone        String?     @map("Phone") @db.VarChar(50)
  email        String?     @map("Email") @db.VarChar(100)
  address      String?     @map("Address") @db.Text
  taxId        String?     @map("TaxID") @db.VarChar(50)
  paymentType  PaymentType @default(CASH) @map("PaymentType")
  paymentTerm  Int         @default(0) @map("PaymentTerm")
  bankName     String?     @map("BankName") @db.VarChar(100)
  bankAccount  String?     @map("BankAccount") @db.VarChar(100)
  accountName  String?     @map("AccountName") @db.VarChar(255)
  isActive     Boolean     @default(true) @map("IsActive")
  note         String?     @map("Note") @db.Text
  categories   String?     @map("Categories") @db.Text
  brands       String?     @map("Brands") @db.Text
  companyId    String      @map("CompanyID") @db.VarChar(191)
  createdAt    DateTime    @default(now()) @map("CreatedAt")
  updatedAt    DateTime    @updatedAt @map("UpdatedAt")
  company      Company     @relation("VendorCompany", fields: [companyId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([companyId, vendorCode])
  @@index([companyId])
}

model Company {
  id           String        @id @default(cuid()) @map("ID") @db.VarChar(191)
  companyCode  String        @unique @map("CompanyCode") @db.VarChar(50)
  name         String        @map("Name") @db.VarChar(255)
  nameEn       String?       @map("NameEn") @db.VarChar(255)
  taxId        String?       @map("TaxID") @db.VarChar(50)
  branch       String?       @map("Branch") @db.VarChar(50)
  address      String?       @map("Address") @db.Text
  phone        String?       @map("Phone") @db.VarChar(50)
  email        String?       @map("Email") @db.VarChar(100)
  website      String?       @map("Website") @db.VarChar(255)
  logoUrl      String?       @map("LogoUrl") @db.VarChar(500)
  signatureUrl String?       @map("SignatureUrl") @db.VarChar(500)
  bankName     String?       @map("BankName") @db.VarChar(100)
  bankAccount  String?       @map("BankAccount") @db.VarChar(100)
  accountName  String?       @map("AccountName") @db.VarChar(255)
  isActive     Boolean       @default(true) @map("IsActive")
  createdAt    DateTime      @default(now()) @map("CreatedAt")
  updatedAt    DateTime      @updatedAt @map("UpdatedAt")
  users        User[]
  documents    Document[]    @relation("DocumentCompany")
  customers    Customer[]    @relation("CustomerCompany")
  products     Product[]     @relation("ProductCompany")
  vendors      Vendor[]      @relation("VendorCompany")
  destinations Destination[] @relation("DestinationCompany")
  unitCodes             UnitCode[]             @relation("UnitCodeCompany")
  paymentTerms          PaymentTerm[]          @relation("PaymentTermCompany")
  systemActivations     SystemActivation[]
  purchaseRequisitions  PurchaseRequisition[]  @relation("PRCompany")
  goodsReceipts         GoodsReceipt[]         @relation("GRCompany")
  stockTransactions     StockTransaction[]     @relation("StockTransactionCompany")
  saleOrders            SaleOrder[]            @relation("SOCompany")
  serialNumbers         SerialNumber[]         @relation("SerialNumberCompany")

  @@index([companyCode])
}

model Document {
  id                     String                  @id @map("ID") @db.Char(26)
  documentType           DocumentType            @map("DocumentType")
  documentNumber         String                  @map("DocumentNumber") @db.VarChar(50)
  title                  String?                 @map("Title") @db.VarChar(255)
  documentDate           DateTime?               @map("DocumentDate")
  customerId             String?                 @map("CustomerID") @db.VarChar(10)
  billTo                 String?                 @map("BillTo") @db.VarChar(255)
  shipTo                 String?                 @map("ShipTo") @db.VarChar(255)
  destinationId          String?                 @map("DestinationID") @db.VarChar(10)
  paymentTermId          String?                 @map("PaymentTermID") @db.VarChar(10)
  paymentMethod          String?                 @map("PaymentMethod") @db.VarChar(100)
  referenceNo            String?                 @map("ReferenceNo") @db.VarChar(100)
  status                 String?                 @map("Status") @db.VarChar(30)
  remark                 String?                 @map("Remark") @db.VarChar(500)
  totalCost              Decimal?                @map("TotalCost") @db.Decimal(19, 4)
  totalSellingPrice      Decimal?                @map("TotalSellingPrice") @db.Decimal(19, 4)
  totalProfit            Decimal?                @map("TotalProfit") @db.Decimal(19, 4)
  margin                 Decimal?                @map("Margin") @db.Decimal(19, 4)
  taxRate                Decimal?                @map("TaxRate") @db.Decimal(10, 4)
  taxAmount              Decimal?                @map("TaxAmount") @db.Decimal(19, 4)
  totalAmount            Decimal?                @map("TotalAmount") @db.Decimal(19, 4)
  totalQuantity          Decimal?                @map("TotalQuantity") @db.Decimal(18, 2)
  companyId              String                  @map("CompanyID") @db.VarChar(191)
  createdAt              DateTime                @default(now()) @map("CreatedAt")
  updatedAt              DateTime                @updatedAt @map("UpdatedAt")
  company                Company                 @relation("DocumentCompany", fields: [companyId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  items                  DocumentItem[]
  quotationDocument      QuotationDocument?
  invoiceDocument        InvoiceDocument?
  receiptDocument        ReceiptDocument?
  depositReceiptDocument DepositReceiptDocument?
  depositInvoiceDocument DepositInvoiceDocument?
  purchaseOrderDocument  PurchaseOrderDocument?
  workOrderDocument      WorkOrderDocument?
  deliveryOrderDocument  DeliveryOrderDocument?
  customerReturnDocument CustomerReturnDocument?

  @@unique([companyId, documentType, documentNumber])
  @@index([companyId, documentType, documentDate])
}

model DocumentItem {
  id                String       @id @map("ID") @db.Char(26)
  documentId        String       @map("DocumentID") @db.Char(26)
  documentNumber    String       @map("DocumentNumber") @db.Char(26)
  documentType      DocumentType @map("DocumentType")
  lineNo            Int          @map("LineNo")
  productCode       String?      @map("ProductCode") @db.VarChar(50)
  vendorCode        String?      @map("VendorCode") @db.VarChar(50)
  cost              Decimal?     @map("Cost") @db.Decimal(19, 4)
  quantity          Decimal?     @map("Quantity") @db.Decimal(19, 4)
  margin            Decimal?     @map("Margin") @db.Decimal(19, 4)
  sellingPrice      Decimal?     @map("SellingPrice") @db.Decimal(19, 4)
  totalCost         Decimal?     @map("TotalCost") @db.Decimal(19, 4)
  totalSellingPrice Decimal?     @map("TotalSellingPrice") @db.Decimal(19, 4)
  unitId            String?      @map("UnitID") @db.VarChar(10)
  createdAt         DateTime     @default(now()) @map("CreatedAt")
  updatedAt         DateTime     @updatedAt @map("UpdatedAt")
  document          Document     @relation(fields: [documentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([documentType, documentNumber, lineNo])
  @@index([documentId])
  @@index([documentNumber, lineNo, documentType])
}

model QuotationDocument {
  id                  String   @id @map("ID") @db.Char(26)
  documentNumber      String   @map("DocumentNumber") @db.Char(26)
  attentionTo         String?  @map("AttentionTo") @db.VarChar(255)
  linkedInvoiceId     String?  @map("LinkedInvoiceId") @db.VarChar(26)
  linkedInvoiceNumber String?  @map("LinkedInvoiceNumber") @db.VarChar(50)
  createdBy           String?  @map("CreatedBy") @db.VarChar(255)
  approvedBy          String?  @map("ApprovedBy") @db.VarChar(255)
  document            Document @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model InvoiceDocument {
  id                         String    @id @map("ID") @db.Char(26)
  documentNumber             String    @map("DocumentNumber") @db.Char(26)
  dueDate                    DateTime? @map("DueDate")
  doNo                       String?   @map("DoNo") @db.VarChar(255)
  linkedReceiptId            String?   @map("LinkedReceiptId") @db.VarChar(26)
  linkedReceiptNumber        String?   @map("LinkedReceiptNumber") @db.VarChar(50)
  linkedDepositReceiptId     String?   @map("LinkedDepositReceiptId") @db.VarChar(26)
  linkedDepositReceiptNumber String?   @map("LinkedDepositReceiptNumber") @db.VarChar(50)
  depositAmountDeducted      Decimal?  @map("DepositAmountDeducted") @db.Decimal(19, 4)
  linkedSOId                 String?   @map("LinkedSOId") @db.VarChar(191)
  customerTaxId              String?   @map("CustomerTaxId") @db.VarChar(20)
  customerBranch             String?   @map("CustomerBranch") @db.VarChar(100)
  paymentStatus              String    @default("PENDING") @map("PaymentStatus") @db.VarChar(20)
  document                   Document  @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model ReceiptDocument {
  id                     String    @id @map("ID") @db.Char(26)
  documentNumber         String    @map("DocumentNumber") @db.Char(26)
  receivedDate           DateTime? @map("ReceivedDate")
  paymentReference       String?   @map("PaymentReference") @db.VarChar(100)
  linkedDepositReceiptId String?   @map("LinkedDepositReceiptId") @db.VarChar(26)
  linkedSOId             String?   @map("LinkedSOId") @db.VarChar(191)
  depositAmountDeducted  Decimal?  @map("DepositAmountDeducted") @db.Decimal(19, 4)
  linkedDOId             String?   @map("LinkedDOId") @db.VarChar(26)
  document               Document  @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model DepositReceiptDocument {
  id                    String    @id @map("ID") @db.Char(26)
  documentNumber        String    @map("DocumentNumber") @db.Char(26)
  receivedDate          DateTime? @map("ReceivedDate")
  paymentReference      String?   @map("PaymentReference") @db.VarChar(100)
  paymentAmount         Decimal?  @map("PaymentAmount") @db.Decimal(19, 4)
  paymentType           String?   @map("PaymentType") @db.VarChar(30)
  linkedQuotationId     String?   @map("LinkedQuotationId") @db.VarChar(26)
  linkedQuotationNumber String?   @map("LinkedQuotationNumber") @db.VarChar(50)
  linkedSOId            String?   @map("LinkedSOId") @db.VarChar(191)
  linkedDIId            String?   @map("LinkedDIId") @db.VarChar(26)
  linkedDINumber        String?   @map("LinkedDINumber") @db.VarChar(50)
  document              Document  @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model PurchaseOrderDocument {
  id                String    @id @map("ID") @db.Char(26)
  documentNumber    String    @map("DocumentNumber") @db.Char(26)
  vendorCode        String?   @map("VendorCode") @db.VarChar(50)
  supplierName      String?   @map("SupplierName") @db.VarChar(255)
  deliveryDate      DateTime? @map("DeliveryDate")
  vendorQuotationNo String?   @map("VendorQuotationNo") @db.VarChar(100)
  document          Document  @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model WorkOrderDocument {
  id             String    @id @map("ID") @db.Char(26)
  documentNumber String    @map("DocumentNumber") @db.Char(26)
  scheduledDate  DateTime? @map("ScheduledDate")
  assignedTo     String?   @map("AssignedTo") @db.VarChar(255)
  document       Document  @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model SystemActivation {
  id          String   @id @map("ID") @db.Char(26)
  adminToken  String   @unique @map("AdminToken") @db.VarChar(191)
  adminEmail  String?  @map("AdminEmail") @db.VarChar(191)
  companyId   String?  @map("CompanyId") @db.VarChar(191)
  activatedAt DateTime @default(now()) @map("ActivatedAt")
  createdAt   DateTime @default(now()) @map("CreatedAt")
  updatedAt   DateTime @updatedAt @map("UpdatedAt")
  company     Company? @relation(fields: [companyId], references: [id])
}

model PurchaseRequisition {
  id           String    @id @default(cuid()) @map("ID") @db.VarChar(191)
  prNumber     String    @map("PRNumber") @db.VarChar(50)
  title        String    @map("Title") @db.VarChar(255)
  requestedBy  String?   @map("RequestedBy") @db.VarChar(255)
  vendorCode   String?   @map("VendorCode") @db.VarChar(50)
  requiredDate DateTime? @map("RequiredDate")
  status       String    @default("DRAFT") @map("Status") @db.VarChar(30)
  remark       String?   @map("Remark") @db.VarChar(500)
  approvedBy   String?   @map("ApprovedBy") @db.VarChar(255)
  approvedAt   DateTime? @map("ApprovedAt")
  rejectedBy   String?   @map("RejectedBy") @db.VarChar(255)
  rejectedAt   DateTime? @map("RejectedAt")
  rejectReason String?   @map("RejectReason") @db.VarChar(500)
  companyId    String    @map("CompanyID") @db.VarChar(191)
  createdAt    DateTime  @default(now()) @map("CreatedAt")
  updatedAt    DateTime  @updatedAt @map("UpdatedAt")
  company      Company   @relation("PRCompany", fields: [companyId], references: [id])
  items        PRItem[]

  @@unique([companyId, prNumber])
  @@index([companyId])
  @@map("PurchaseRequisition")
}

model PRItem {
  id             String              @id @default(cuid()) @map("ID") @db.VarChar(191)
  prId           String              @map("PRID") @db.VarChar(191)
  lineNo         Int                 @map("LineNo")
  productCode    String?             @map("ProductCode") @db.VarChar(50)
  description    String              @map("Description") @db.VarChar(255)
  qty            Decimal             @default(0) @map("Qty") @db.Decimal(18, 2)
  unit           String?             @map("Unit") @db.VarChar(50)
  estimatedPrice Decimal             @default(0) @map("EstimatedPrice") @db.Decimal(19, 4)
  remark         String?             @map("Remark") @db.VarChar(255)
  convertedToPo  Boolean             @default(false) @map("ConvertedToPO")
  poNumber       String?             @map("PONumber") @db.VarChar(50)
  pr             PurchaseRequisition @relation(fields: [prId], references: [id], onDelete: Cascade)

  @@index([prId])
  @@map("PRItem")
}

model GoodsReceipt {
  id          String    @id @default(cuid()) @map("ID") @db.VarChar(191)
  grNumber    String    @map("GRNumber") @db.VarChar(50)
  poId        String    @map("POID") @db.VarChar(26)
  poNumber    String    @map("PONumber") @db.VarChar(50)
  vendorCode  String?   @map("VendorCode") @db.VarChar(50)
  receivedDate DateTime? @map("ReceivedDate")
  status      String    @default("DRAFT") @map("Status") @db.VarChar(30)
  remark      String?   @map("Remark") @db.VarChar(500)
  receivedBy  String?   @map("ReceivedBy") @db.VarChar(255)
  confirmedBy String?   @map("ConfirmedBy") @db.VarChar(255)
  confirmedAt DateTime? @map("ConfirmedAt")
  companyId   String    @map("CompanyID") @db.VarChar(191)
  createdAt   DateTime  @default(now()) @map("CreatedAt")
  updatedAt   DateTime  @updatedAt @map("UpdatedAt")
  company     Company   @relation("GRCompany", fields: [companyId], references: [id])
  items       GRItem[]

  @@unique([companyId, grNumber])
  @@index([companyId])
  @@map("GoodsReceipt")
}

model GRItem {
  id           String       @id @default(cuid()) @map("ID") @db.VarChar(191)
  grId         String       @map("GRID") @db.VarChar(191)
  lineNo       Int          @map("LineNo")
  productCode  String?      @map("ProductCode") @db.VarChar(50)
  description  String       @map("Description") @db.VarChar(255)
  poQty        Decimal      @default(0) @map("POQty") @db.Decimal(18, 2)
  receivedQty  Decimal      @default(0) @map("ReceivedQty") @db.Decimal(18, 2)
  unit         String?      @map("Unit") @db.VarChar(50)
  unitPrice    Decimal      @default(0) @map("UnitPrice") @db.Decimal(19, 4)
  remark       String?      @map("Remark") @db.VarChar(255)
  serialNumber String?      @map("SerialNumber") @db.VarChar(100)
  gr           GoodsReceipt @relation(fields: [grId], references: [id], onDelete: Cascade)

  @@index([grId])
  @@map("GRItem")
}

model SerialNumber {
  id           String             @id @map("ID") @db.VarChar(26)
  serialNumber String             @map("SerialNumber") @db.VarChar(100)
  productId    String             @map("ProductID") @db.VarChar(26)
  productCode  String             @map("ProductCode") @db.VarChar(50)
  companyId    String             @map("CompanyID") @db.VarChar(191)
  status       SerialNumberStatus @default(AVAILABLE) @map("Status")
  grId         String?            @map("GRID") @db.VarChar(191)
  grNumber     String?            @map("GRNumber") @db.VarChar(50)
  grItemId     String?            @map("GRItemID") @db.VarChar(191)
  doId         String?            @map("DOID") @db.VarChar(26)
  doNumber     String?            @map("DONumber") @db.VarChar(50)
  soId         String?            @map("SOID") @db.VarChar(191)
  soNumber     String?            @map("SONumber") @db.VarChar(50)
  soldAt       DateTime?          @map("SoldAt")
  createdAt    DateTime           @default(now()) @map("CreatedAt")
  updatedAt    DateTime           @updatedAt @map("UpdatedAt")
  product      Product            @relation(fields: [productId], references: [id], onDelete: Restrict)
  company      Company            @relation("SerialNumberCompany", fields: [companyId], references: [id])

  @@unique([companyId, serialNumber])
  @@index([companyId, productCode, status])
  @@index([companyId, status])
  @@index([grId])
  @@map("SerialNumber")
}

model DeliveryOrderDocument {
  id              String   @id @map("ID") @db.Char(26)
  documentNumber  String   @map("DocumentNumber") @db.Char(26)
  quotationId     String?  @map("QuotationId") @db.VarChar(26)
  quotationNumber String?  @map("QuotationNumber") @db.VarChar(50)
  linkedSOId      String?  @map("LinkedSOId") @db.VarChar(191)
  companyId       String?  @map("CompanyID") @db.VarChar(191)
  document        Document @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([companyId, linkedSOId])
}

model CustomerReturnDocument {
  id             String   @id @map("ID") @db.Char(26)
  documentNumber String   @map("DocumentNumber") @db.Char(26)
  refDocNumber   String?  @map("RefDocNumber") @db.VarChar(50)
  document       Document @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model SaleOrder {
  id           String    @id @default(cuid()) @map("ID") @db.VarChar(191)
  soNumber     String    @map("SONumber") @db.VarChar(50)
  customerCode String?   @map("CustomerCode") @db.VarChar(50)
  customerName String    @map("CustomerName") @db.VarChar(255)
  salesPerson  String?   @map("SalesPerson") @db.VarChar(255)
  soDate       DateTime  @default(now()) @map("SODate")
  requiredDate DateTime? @map("RequiredDate")
  status       String    @default("DRAFT") @map("Status") @db.VarChar(30)
  paymentTerm  String?   @map("PaymentTerm") @db.VarChar(50)
  remark       String?   @map("Remark") @db.VarChar(500)
  companyId    String    @map("CompanyID") @db.VarChar(191)
  createdAt    DateTime  @default(now()) @map("CreatedAt")
  updatedAt    DateTime  @updatedAt @map("UpdatedAt")
  company      Company   @relation("SOCompany", fields: [companyId], references: [id])
  items        SOItem[]

  @@unique([companyId, soNumber])
  @@index([companyId])
  @@map("SaleOrder")
}

model SOItem {
  id           String    @id @default(cuid()) @map("ID") @db.VarChar(191)
  soId         String    @map("SOID") @db.VarChar(191)
  lineNo       Int       @map("LineNo")
  productCode  String?   @map("ProductCode") @db.VarChar(50)
  description  String    @map("Description") @db.VarChar(255)
  qty          Decimal   @default(0) @map("Qty") @db.Decimal(18, 2)
  unit         String?   @map("Unit") @db.VarChar(50)
  unitPrice    Decimal   @default(0) @map("UnitPrice") @db.Decimal(19, 4)
  discount     Decimal   @default(0) @map("Discount") @db.Decimal(5, 2)
  amount       Decimal   @default(0) @map("Amount") @db.Decimal(19, 4)
  deliveredQty Decimal   @default(0) @map("DeliveredQty") @db.Decimal(18, 2)
  convertedToPr Boolean  @default(false) @map("ConvertedToPR")
  prNumber     String?   @map("PRNumber") @db.VarChar(50)
  remark       String?   @map("Remark") @db.VarChar(255)
  so           SaleOrder @relation(fields: [soId], references: [id], onDelete: Cascade)

  @@index([soId])
  @@map("SOItem")
}

model StockTransaction {
  id          String        @id @map("ID") @db.VarChar(26)
  productId   String        @map("ProductID") @db.VarChar(26)
  productCode String        @map("ProductCode") @db.VarChar(50)
  companyId   String        @map("CompanyID") @db.VarChar(191)
  docNumber   String        @map("DocNumber") @db.VarChar(50)
  docType     String        @map("DocType") @db.VarChar(30)
  docId       String?       @map("DocID") @db.VarChar(191)
  type        StockMoveType @map("Type")
  qtyChange   Decimal       @map("QtyChange") @db.Decimal(18, 2)
  createdBy   String?       @map("CreatedBy") @db.VarChar(255)
  createdAt   DateTime      @default(now()) @map("CreatedAt")
  product     Product       @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  company     Company       @relation("StockTransactionCompany", fields: [companyId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([companyId, productCode])
  @@index([companyId, docType, docNumber])
  @@index([productId])
  @@map("StockTransaction")
}

model DepositInvoiceDocument {
  documentId        String   @id @map("DocumentID") @db.Char(26)
  documentNumber    String   @map("DocumentNumber") @db.Char(26)
  linkedQuotationId String?  @map("LinkedQuotationId") @db.VarChar(26)
  linkedSOId        String?  @map("LinkedSOId") @db.VarChar(191)
  depositPercentage Decimal  @map("DepositPercentage") @db.Decimal(5, 2)
  depositAmount     Decimal  @map("DepositAmount") @db.Decimal(19, 4)
  balanceAmount     Decimal  @map("BalanceAmount") @db.Decimal(19, 4)
  linkedDRId        String?  @map("LinkedDRId") @db.VarChar(26)
  linkedDRNumber    String?  @map("LinkedDRNumber") @db.VarChar(50)
  document          Document @relation(fields: [documentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}
