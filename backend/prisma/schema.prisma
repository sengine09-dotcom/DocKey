generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String  @id @db.Char(26)
  email     String  @unique
  password  String
  name      String
  role      String  @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tblUser")
}

model Monitor {
  monitorId      String          @id @map("MonitorID") @db.VarChar(10)
  isCancel       String?         @map("isCancel") @db.VarChar(1)
  issDate        DateTime?       @map("IssDate")
  customerId     String?         @map("CustomerID") @db.VarChar(5)
  supplierId     String?         @map("SupplierID") @db.VarChar(3)
  termId         String?         @map("TermID") @db.VarChar(3)
  poNo           String?         @map("PoNo") @db.VarChar(50)
  poDate         DateTime?       @map("PoDate")
  reqDate        DateTime?       @map("ReqDate")
  eUserId        String?         @map("EUserID") @db.VarChar(3)
  destinationId  String?         @map("DestinationID") @db.VarChar(3)
  totalQuantity  Decimal?        @map("TotalQuantity") @db.Decimal(18, 2)
  totalAmount    Decimal?        @map("TotalAmount") @db.Decimal(19, 4)
  isArranged     String?         @map("isArranged") @db.VarChar(1)
  remark         String?         @map("Remark") @db.VarChar(300)
  status         Int?            @map("Status")
  vat            Int             @map("Vat")
  monitorDetails MonitorDetail[]

  @@map("tblMonitor")
}

model MonitorDetail {
  mdId       Int      @id @default(autoincrement()) @map("MDID")
  idMonitor  String   @map("IDMonitor") @db.VarChar(10)
  item       Int?     @map("Item")
  productId  String   @map("ProductID") @db.VarChar(5)
  quantity   Decimal? @map("Quantity") @db.Decimal(18, 3)
  unitCount  String?  @map("UnitCount") @db.VarChar(3)
  price      Decimal? @map("Price") @db.Decimal(10, 3)
  total      Decimal? @map("Total") @db.Decimal(18, 3)
  supplierId String?  @map("SupplierID") @db.VarChar(10)

  monitor Monitor @relation(fields: [idMonitor], references: [monitorId], onDelete: Restrict, onUpdate: Cascade)

  @@index([idMonitor])
  @@map("tblMonitorDetail")
}

model Invoice {
  invoiceNo      String          @id @map("InvoiceNo") @db.VarChar(8)
  codeNo         String?         @map("CodeNo") @db.VarChar(20)
  idMonitor      String          @map("IDMonitor") @db.VarChar(8)
  isCancel       String?         @map("isCancel") @db.VarChar(1)
  invDate        DateTime?       @map("InvDate")
  poNo           String?         @map("PoNo") @db.VarChar(50)
  doNo           String?         @map("DoNo") @db.VarChar(255)
  customerId     String?         @map("CustomerID") @db.VarChar(10)
  agentId        String?         @map("AgentID") @db.VarChar(5)
  supplierId     String?         @map("SupplierID") @db.VarChar(3)
  termId         String?         @map("TermID") @db.VarChar(10)
  transportId    String?         @map("TransportID") @db.VarChar(10)
  period         Int?            @map("Period")
  destinationId  String?         @map("DestinationID") @db.VarChar(10)
  eUserId        String?         @map("eUserID") @db.VarChar(10)
  totalContainer Decimal?        @map("TotalContainer") @db.Decimal(18, 0)
  totalAmount    Decimal?        @map("TotalAmount") @db.Decimal(19, 4)
  totalQuantity  Decimal?        @map("TotalQuantity") @db.Decimal(18, 2)
  comRate        Decimal?        @map("ComRate") @db.Decimal(19, 4)
  remark         String?         @map("Remark") @db.VarChar(255)
  vat            Int             @map("Vat")
  statusOnline   Int             @map("StatusOnline")
  invoiceDetails InvoiceDetail[]

  @@map("tblInvoice")
}

model InvoiceDetail {
  iid        Int      @id @default(autoincrement()) @map("IID")
  invoiceNo  String   @map("InvoiceNo") @db.VarChar(8)
  item       String?  @map("Item") @db.VarChar(2)
  productId  String   @map("ProductID") @db.VarChar(5)
  quantity   Decimal? @map("Quantity") @db.Decimal(18, 3)
  weight     Decimal? @map("Weight") @db.Decimal(18, 3)
  price      Decimal? @map("Price") @db.Decimal(10, 3)
  unitId     String?  @map("UnitID") @db.VarChar(3)
  total      Decimal? @map("Total") @db.Decimal(18, 3)
  supplierId String?  @map("SupplierID") @db.VarChar(10)
  comRate    Decimal? @map("ComRate") @db.Decimal(18, 2)
  bag        Int?     @map("Bag")

  invoice Invoice @relation(fields: [invoiceNo], references: [invoiceNo], onDelete: Restrict, onUpdate: Cascade)

  @@index([invoiceNo])
  @@map("tblInvoiceDetail")
}

model Customer {
  customerId          String    @id @map("CustomerID") @db.VarChar(5)
  agentId             String?   @map("AgentID") @db.VarChar(5)
  customerName        String?   @map("CustomerName") @db.VarChar(255)
  shortName           String?   @map("ShortName") @db.VarChar(255)
  registerDate        DateTime? @map("RegisterDate")
  registrationNo      String?   @map("RegistrationNo") @db.VarChar(20)
  address             String?   @map("Address") @db.VarChar(500)
  phone               String?   @map("Phone") @db.VarChar(50)
  fax                 String?   @map("Fax") @db.VarChar(20)
  email               String?   @map("Email") @db.VarChar(255)
  contactPerson       String?   @map("ContactPerson") @db.VarChar(50)
  creditLimit         Decimal?  @map("CreditLimit") @db.Decimal(19, 4)
  idTerm              String?   @map("IDTerm") @db.VarChar(3)
  internalTerm        Int?      @map("InternalTerm")
  remark              String?   @map("Remark") @db.VarChar(255)
  used                String?   @map("Used") @db.VarChar(1)
  totalShare          Decimal?  @map("TotalShare") @db.Decimal(19, 4)
  gstId               String?   @map("GSTid") @db.VarChar(15)
  isGuaratee          Int?      @map("IsGuaratee")
  guarateePrice       Decimal?  @map("GuarateePrice") @db.Decimal(19, 4)
  guarateeDateStart   DateTime? @map("GuarateeDateStart")
  guarateeDateEnd     DateTime? @map("GuarateeDateEnd")

  @@map("tblCustomer")
}

model Product {
  productId    String   @id @map("ProductID") @db.VarChar(5)
  productName  String?  @map("ProductName") @db.VarChar(100)
  marking      String?  @map("Marking") @db.VarChar(100)
  type         String?  @map("Type") @db.VarChar(100)
  bagSize      String?  @map("BagSize") @db.VarChar(100)
  pWeight      Float?   @map("PWeight")
  comValue     String?  @map("ComValue") @db.VarChar(1)
  description  String?  @map("Description") @db.VarChar(255)
  idSupplier   String?  @map("IDSupplier") @db.VarChar(3)
  showInStock  String?  @map("ShowInStock") @db.VarChar(1)
  used         String?  @map("Used") @db.VarChar(1)

  @@map("tblProduct")
}

model Destination {
  destId        String   @id @map("DestID") @db.VarChar(3)
  destination   String?  @map("Destination") @db.VarChar(50)
  location      String?  @map("Location") @db.VarChar(50)
  used          String?  @map("Used") @db.VarChar(1)

  @@map("tblDestination")
}
