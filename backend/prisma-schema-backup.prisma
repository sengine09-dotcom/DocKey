// This is a backup of the current schema before major changes
generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum DocumentType {
  QUOTATION
  INVOICE
  RECEIPT
  PURCHASE_ORDER
  WORK_ORDER
}

model User {
  id        String   @id @map("ID") @db.Char(26)
  email     String   @unique @map("Email") @db.VarChar(191)
  password  String   @map("Password") @db.VarChar(255)
  name      String   @map("Name") @db.VarChar(255)
  role      String   @default("user") @map("Role") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("CreatedAt")
  updatedAt DateTime @updatedAt @map("UpdatedAt")

  @@unique([id])
}

model Customer {
  id           String   @id @map("ID") @db.VarChar(26)
  customerCode String   @map("CustomerCode") @db.VarChar(50)
  customerName String   @map("CustomerName") @db.VarChar(255)
  contactName  String?  @map("ContactName") @db.VarChar(255)
  phone        String?  @map("Phone") @db.VarChar(50)
  email        String?  @map("Email") @db.VarChar(191)
  address      String?  @map("Address") @db.VarChar(500)
  taxId        String?  @map("TaxID") @db.VarChar(50)
  branch       String?  @map("Branch") @db.VarChar(255)
  used         String?  @map("Used") @db.VarChar(1)
  createdAt    DateTime @default(now()) @map("CreatedAt")
  updatedAt    DateTime @updatedAt @map("UpdatedAt")

  @@unique([id])
}

model Product {
  id            String         @id @map("ID") @db.VarChar(26)
  productCode   String         @map("ProductCode") @db.VarChar(50)
  productName   String         @map("ProductName") @db.VarChar(255)
  category      String         @map("Category") @db.VarChar(255)
  brand         String         @map("Brand") @db.VarChar(255)
  model         String?        @map("Model") @db.VarChar(255)
  price         Decimal        @map("Price") @db.Decimal(19, 4)
  cost          Decimal?       @map("Cost") @db.Decimal(19, 4)
  stockQty      Int            @default(0) @map("StockQty")
  minQty        Int            @default(0) @map("MinQty")
  maxQty        Int            @default(0) @map("MaxQty")
  createdAt     DateTime       @default(now()) @map("CreatedAt")
  updatedAt     DateTime       @updatedAt @map("UpdatedAt")

  @@unique([id])
}

model Destination {
  id              String  @id @map("ID") @db.VarChar(26)
  destinationCode String  @map("DestinationCode") @db.VarChar(50)
  destination     String? @map("Destination") @db.VarChar(50)
  location        String? @map("Location") @db.VarChar(50)
  used            String? @map("Used") @db.VarChar(1)
}

model PaymentTerm {
  id        String  @id @map("ID") @db.VarChar(26)
  termCode  String  @map("TermCode") @db.VarChar(50)
  termName  String? @map("TermName") @db.VarChar(50)
  shortName String? @map("ShortName") @db.VarChar(20)
  days      String? @map("Days") @db.VarChar(3)
  used      String? @map("Used") @db.VarChar(1)
}

model Document {
  id                String                @id @map("ID") @db.Char(26)
  documentNumber    String                @map("DocumentNumber") @db.Char(26)
  documentType     DocumentType           @map("DocumentType")
  documentDate     DateTime              @default(now()) @map("DocumentDate")
  customerId       String?               @map("CustomerID") @db.VarChar(26)
  title            String?               @map("Title") @db.VarChar(255)
  billTo           String?               @map("BillTo") @db.VarChar(500)
  shipTo           String?               @map("ShipTo") @db.VarChar(500)
  destination       String?               @map("Destination") @db.VarChar(255)
  paymentTerm      String?               @map("PaymentTerm") @db.VarChar(26)
  paymentMethod    String?               @map("PaymentMethod") @db.VarChar(100)
  referenceNo      String?               @map("ReferenceNo") @db.VarChar(100)
  status           String?               @map("Status") @db.VarChar(30)
  remark            String?               @map("Remark") @db.VarChar(500)
  totalCost        Decimal?             @map("TotalCost") @db.Decimal(19, 4)
  totalSellingPrice Decimal?             @map("TotalSellingPrice") @db.Decimal(19, 4)
  totalProfit      Decimal?             @map("TotalProfit") @db.Decimal(19, 4)
  margin           Decimal?             @map("Margin") @db.Decimal(19, 4)
  taxRate          Decimal?             @map("TaxRate") @db.Decimal(10, 4)
  taxAmount        Decimal?             @map("TaxAmount") @db.Decimal(19, 4)
  totalAmount       Decimal?             @map("TotalAmount") @db.Decimal(19, 4)
  totalQuantity     Decimal?             @map("TotalQuantity") @db.Decimal(18, 2)
  createdAt        DateTime              @default(now()) @map("CreatedAt")
  updatedAt        DateTime              @updatedAt @map("UpdatedAt")

  @@unique([documentType, documentNumber])
  @@index([documentType, documentDate])
}

model DocumentItem {
  id                String       @id @map("ID") @db.Char(26)
  documentNumber    String       @map("DocumentNumber") @db.Char(26)
  documentType      DocumentType @map("DocumentType")
  lineNo            Int          @map("LineNo")
  productCode       String?      @map("ProductCode") @db.VarChar(50)
  cost              Decimal?     @map("Cost") @db.Decimal(19, 4)
  quantity          Decimal?     @map("Quantity") @db.Decimal(19, 4)
  margin            Decimal?     @map("Margin") @db.Decimal(19, 4)
  sellingPrice      Decimal?     @map("SellingPrice") @db.Decimal(19, 4)
  totalCost         Decimal?     @map("TotalCost") @db.Decimal(19, 4)
  totalSellingPrice Decimal?     @map("TotalSellingPrice") @db.Decimal(19, 4)
  unitId            String?      @map("UnitID") @db.VarChar(10)
  createdAt         DateTime     @default(now()) @map("CreatedAt")
  updatedAt         DateTime     @updatedAt @map("UpdatedAt")

  @@unique([id, documentType, documentNumber, lineNo])
  @@index([documentNumber, lineNo, documentType])
}

model QuotationDocument {
  id                  String   @id @map("ID") @db.Char(26)
  documentNumber      String   @map("DocumentNumber") @db.Char(26)
  attentionTo         String?  @map("AttentionTo") @db.VarChar(255)
  linkedInvoiceId     String?  @map("LinkedInvoiceId") @db.VarChar(26)
  linkedInvoiceNumber String?  @map("LinkedInvoiceNumber") @db.VarChar(50)
}

model InvoiceDocument {
  id                  String    @id @map("ID") @db.Char(26)
  documentNumber      String    @map("DocumentNumber") @db.Char(26)
  dueDate             DateTime? @map("DueDate")
  doNo                String?   @map("DoNo") @db.VarChar(255)
  linkedReceiptId     String?   @map("LinkedReceiptId") @db.VarChar(26)
  linkedReceiptNumber String?   @map("LinkedReceiptNumber") @db.VarChar(50)
}

model ReceiptDocument {
  id               String    @id @map("ID") @db.Char(26)
  documentNumber   String    @map("DocumentNumber") @db.Char(26)
  receivedDate     DateTime? @map("ReceivedDate")
  paymentReference String?   @map("PaymentReference") @db.VarChar(100)
}

model PurchaseOrderDocument {
  id             String    @id @map("ID") @db.Char(26)
  documentNumber String    @map("DocumentNumber") @db.Char(26)
  supplierName   String?   @map("SupplierName") @db.VarChar(255)
  deliveryDate   DateTime? @map("DeliveryDate")
}

model WorkOrderDocument {
  id             String    @id @map("ID") @db.Char(26)
  documentNumber String    @map("DocumentNumber") @db.Char(26)
  scheduledDate  DateTime? @map("ScheduledDate")
  assignedTo    String?   @map("AssignedTo") @db.VarChar(255)
}

model SystemActivation {
  id          String   @id @map("ID") @db.Char(26)
  adminToken  String   @unique @map("AdminToken") @db.VarChar(191)
  adminEmail  String?  @map("AdminEmail") @db.VarChar(191)
  activatedAt DateTime @default(now()) @map("ActivatedAt")
  createdAt   DateTime @default(now()) @map("CreatedAt")
  updatedAt   DateTime @updatedAt @map("UpdatedAt")
}
